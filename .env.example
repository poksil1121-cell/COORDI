# ── AI 맞춤 추천 기능(선택) 설정 ──────────────────────────────
# 이 파일을 복사해서 ".env" 파일을 만들고 값을 채워주세요.
#   cp .env.example .env
#
# ANTHROPIC_API_KEY가 없어도 앱의 핵심 기능(날씨 조회 + 규칙 기반
# 헤어/스킨/메이크업/코디 추천)은 정상적으로 동작합니다.
# 이 키는 "AI에게 코디 조언 더 받기" 버튼을 눌렀을 때만 사용됩니다.

# https://console.anthropic.com/ 에서 발급받은 API 키
ANTHROPIC_API_KEY=sk-ant-여기에-발급받은-키를-입력하세요

# 사용할 모델 (기본값: claude-sonnet-5 / 비용을 아끼려면 claude-haiku-4-5-20251001 로 변경)
ANTHROPIC_MODEL=claude-sonnet-5

# 서버 포트 (기본값 3000)
PORT=3000
